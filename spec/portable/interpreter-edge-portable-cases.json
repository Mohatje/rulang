[
  {
    "id": "interpreter::truthiness::bare_boolean_true",
    "kind": "evaluate",
    "mode": "first_match",
    "rules": [
      "entity.enabled => entity.result = 'yes'"
    ],
    "input": {
      "enabled": true,
      "result": "no"
    },
    "expected_result": true,
    "expected_entity": {
      "enabled": true,
      "result": "yes"
    }
  },
  {
    "id": "interpreter::truthiness::bare_boolean_false",
    "kind": "evaluate",
    "mode": "first_match",
    "rules": [
      "entity.enabled => entity.result = 'yes'"
    ],
    "input": {
      "enabled": false,
      "result": "no"
    },
    "expected_result": null,
    "expected_entity": {
      "enabled": false,
      "result": "no"
    }
  },
  {
    "id": "interpreter::truthiness::numeric_true",
    "kind": "evaluate",
    "mode": "first_match",
    "rules": [
      "entity.count => entity.has_items = true"
    ],
    "input": {
      "count": 5,
      "has_items": false
    },
    "expected_result": true,
    "expected_entity": {
      "count": 5,
      "has_items": true
    }
  },
  {
    "id": "interpreter::truthiness::numeric_false",
    "kind": "evaluate",
    "mode": "first_match",
    "rules": [
      "entity.count => entity.has_items = true"
    ],
    "input": {
      "count": 0,
      "has_items": false
    },
    "expected_result": null,
    "expected_entity": {
      "count": 0,
      "has_items": false
    }
  },
  {
    "id": "interpreter::truthiness::string_true",
    "kind": "evaluate",
    "mode": "first_match",
    "rules": [
      "entity.name => entity.has_name = true"
    ],
    "input": {
      "name": "John",
      "has_name": false
    },
    "expected_result": true,
    "expected_entity": {
      "name": "John",
      "has_name": true
    }
  },
  {
    "id": "interpreter::truthiness::string_false",
    "kind": "evaluate",
    "mode": "first_match",
    "rules": [
      "entity.name => entity.has_name = true"
    ],
    "input": {
      "name": "",
      "has_name": false
    },
    "expected_result": null,
    "expected_entity": {
      "name": "",
      "has_name": false
    }
  },
  {
    "id": "interpreter::dynamic_path_index::config_lookup",
    "kind": "evaluate",
    "mode": "first_match",
    "rules": [
      "entity.config[entity.setting_name] == 'enabled' => entity.active = true"
    ],
    "input": {
      "config": {
        "feature_x": "enabled",
        "feature_y": "disabled"
      },
      "setting_name": "feature_x",
      "active": false
    },
    "expected_result": true,
    "expected_entity": {
      "config": {
        "feature_x": "enabled",
        "feature_y": "disabled"
      },
      "setting_name": "feature_x",
      "active": true
    }
  },
  {
    "id": "interpreter::arithmetic::multiple_add_sub",
    "kind": "evaluate",
    "mode": "first_match",
    "rules": [
      "entity.a + entity.b - entity.c + entity.d > 10 => entity.result = true"
    ],
    "input": {
      "a": 5,
      "b": 10,
      "c": 2,
      "d": 3,
      "result": false
    },
    "expected_result": true,
    "expected_entity": {
      "a": 5,
      "b": 10,
      "c": 2,
      "d": 3,
      "result": true
    }
  },
  {
    "id": "interpreter::arithmetic::multiple_subtractions",
    "kind": "evaluate",
    "mode": "first_match",
    "rules": [
      "entity.x - entity.y - entity.z == 5 => entity.correct = true"
    ],
    "input": {
      "x": 20,
      "y": 10,
      "z": 5,
      "correct": false
    },
    "expected_result": true,
    "expected_entity": {
      "x": 20,
      "y": 10,
      "z": 5,
      "correct": true
    }
  },
  {
    "id": "interpreter::arithmetic::multiple_multiplications",
    "kind": "evaluate",
    "mode": "first_match",
    "rules": [
      "entity.a * entity.b * entity.c > 50 => entity.result = true"
    ],
    "input": {
      "a": 2,
      "b": 5,
      "c": 6,
      "result": false
    },
    "expected_result": true,
    "expected_entity": {
      "a": 2,
      "b": 5,
      "c": 6,
      "result": true
    }
  },
  {
    "id": "interpreter::arithmetic::mixed_mul_div_mod",
    "kind": "evaluate",
    "mode": "first_match",
    "rules": [
      "entity.a * entity.b / entity.c % entity.d == 2 => entity.ok = true"
    ],
    "input": {
      "a": 10,
      "b": 6,
      "c": 4,
      "d": 5,
      "ok": false
    },
    "expected_result": null,
    "expected_entity": {
      "a": 10,
      "b": 6,
      "c": 4,
      "d": 5,
      "ok": false
    }
  },
  {
    "id": "interpreter::return::complex_expression",
    "kind": "evaluate",
    "mode": "first_match",
    "rules": [
      "entity.x > 0 => ret (entity.x + entity.y) * 2"
    ],
    "input": {
      "x": 5,
      "y": 3
    },
    "expected_result": 16,
    "expected_entity": {
      "x": 5,
      "y": 3
    }
  },
  {
    "id": "interpreter::return::builtin_function_result",
    "kind": "evaluate",
    "mode": "first_match",
    "rules": [
      "entity.name != '' => ret upper(entity.name)"
    ],
    "input": {
      "name": "hello"
    },
    "expected_result": "HELLO",
    "expected_entity": {
      "name": "hello"
    }
  },
  {
    "id": "interpreter::return::mutation_then_expression",
    "kind": "evaluate",
    "mode": "first_match",
    "rules": [
      "entity.x > 0 => entity.y = 1; ret entity.y * 2"
    ],
    "input": {
      "x": 5,
      "y": 0
    },
    "expected_result": 2,
    "expected_entity": {
      "x": 5,
      "y": 1
    }
  },
  {
    "id": "interpreter::assignment::list_literal",
    "kind": "evaluate",
    "mode": "first_match",
    "rules": [
      "entity.init == true => entity.items = [1, 2, 3]"
    ],
    "input": {
      "init": true,
      "items": []
    },
    "expected_result": true,
    "expected_entity": {
      "init": true,
      "items": [
        1,
        2,
        3
      ]
    }
  },
  {
    "id": "interpreter::unary::minus_in_condition",
    "kind": "evaluate",
    "mode": "first_match",
    "rules": [
      "-entity.value > 0 => entity.negative = true"
    ],
    "input": {
      "value": -5,
      "negative": false
    },
    "expected_result": true,
    "expected_entity": {
      "value": -5,
      "negative": true
    }
  },
  {
    "id": "interpreter::unary::minus_in_assignment",
    "kind": "evaluate",
    "mode": "first_match",
    "rules": [
      "entity.x > 0 => entity.y = -entity.x"
    ],
    "input": {
      "x": 10,
      "y": 0
    },
    "expected_result": true,
    "expected_entity": {
      "x": 10,
      "y": -10
    }
  },
  {
    "id": "interpreter::actions::all_compound_assignments",
    "kind": "evaluate",
    "mode": "all_match",
    "rules": [
      "entity.a > 0 => entity.a += 5",
      "entity.b > 0 => entity.b -= 3",
      "entity.c > 0 => entity.c *= 2",
      "entity.d > 0 => entity.d /= 4"
    ],
    "input": {
      "a": 10,
      "b": 10,
      "c": 10,
      "d": 20
    },
    "expected_result": true,
    "expected_entity": {
      "a": 15,
      "b": 7,
      "c": 20,
      "d": 5
    }
  },
  {
    "id": "interpreter::workflow::literal_arguments",
    "kind": "evaluate",
    "mode": "first_match",
    "rules": [
      "true => ret workflow('add', 10, 20)"
    ],
    "input": {},
    "workflows": [
      {
        "name": "add",
        "steps": [
          {
            "type": "return",
            "value": {
              "type": "binary",
              "op": "add",
              "left": {
                "type": "arg",
                "index": 0
              },
              "right": {
                "type": "arg",
                "index": 1
              }
            }
          }
        ]
      }
    ],
    "expected_result": 30,
    "expected_entity": {}
  },
  {
    "id": "interpreter::workflow::nested_call",
    "kind": "evaluate",
    "mode": "first_match",
    "rules": [
      "true => ret workflow('outer', workflow('inner'))"
    ],
    "input": {},
    "workflows": [
      {
        "name": "inner",
        "steps": [
          {
            "type": "return",
            "value": {
              "type": "literal",
              "value": 10
            }
          }
        ]
      },
      {
        "name": "outer",
        "steps": [
          {
            "type": "return",
            "value": {
              "type": "binary",
              "op": "mul",
              "left": {
                "type": "arg",
                "index": 0
              },
              "right": {
                "type": "literal",
                "value": 2
              }
            }
          }
        ]
      }
    ],
    "expected_result": 20,
    "expected_entity": {}
  },
  {
    "id": "interpreter::evaluate_error::unknown_function",
    "kind": "evaluate_error",
    "mode": "first_match",
    "rules": [
      "unknown_func(entity.value) > 0 => entity.result = true"
    ],
    "input": {
      "value": 10,
      "result": false
    },
    "expected_error": "EvaluationError"
  },
  {
    "id": "interpreter::evaluate_error::function_error_wrapped",
    "kind": "evaluate_error",
    "mode": "first_match",
    "rules": [
      "int(entity.value) > 0 => entity.ok = true"
    ],
    "input": {
      "value": "not_a_number",
      "ok": false
    },
    "expected_error": "EvaluationError"
  },
  {
    "id": "interpreter::workflow::exception_wrapped",
    "kind": "evaluate_error",
    "mode": "first_match",
    "rules": [
      "entity.value > 0 => workflow('raise_error')"
    ],
    "input": {
      "value": 10
    },
    "workflows": [
      {
        "name": "raise_error",
        "steps": [
          {
            "type": "raise",
            "message": "Test error"
          }
        ]
      }
    ],
    "expected_error": "EvaluationError"
  }
]
